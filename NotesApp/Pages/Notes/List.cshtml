@page
@model ListModel
@{
    ViewData["Title"] = "Moje poznámky";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Moje poznámky</h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Notes/Create" class="btn btn-success">+ Nová poznámka</a>
        </div>
    </div>

    <!-- Filtr -->
    <div class="row mb-3">
        <div class="col-md-12">
            <form method="get" class="d-flex gap-2">
                @if (Model.ShowOnlyImportant)
                {
                    <a href="/Notes/List" class="btn btn-outline-primary">Všechny poznámky</a>
                    <button type="submit" class="btn btn-primary" name="ShowOnlyImportant" value="true" disabled>
                        ⭐ Pouze důležité
                    </button>
                }
                else
                {
                    <a href="/Notes/List?ShowOnlyImportant=true" class="btn btn-outline-primary">⭐ Pouze důležité</a>
                }
            </form>
        </div>
    </div>

    <!-- Seznam poznámek -->
    @if (Model.Notes.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            @if (Model.ShowOnlyImportant)
            {
                <p>Nemáte žádné důležité poznámky. <a href="/Notes/List">Zobrazit všechny</a></p>
            }
            else
            {
                <p>Zatím nemáte žádné poznámky. <a href="/Notes/Create">Vytvořit novou</a></p>
            }
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var note in Model.Notes)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-header bg-light">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title mb-0">@note.Title</h5>
                                @if (note.IsImportant)
                                {
                                    <span class="badge bg-warning text-dark">⭐ Důležitá</span>
                                }
                            </div>
                            <small class="text-muted">
                                @note.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@note.Content</p>
                        </div>
                        <div class="card-footer bg-light">
                            <form method="post" class="d-flex gap-2">
                                @if (note.IsImportant)
                                {
                                    <button type="submit" asp-page-handler="ToggleImportant" asp-route-noteId="@note.Id" 
                                            class="btn btn-sm btn-outline-warning" title="Odebrat z důležitých">
                                        ☆ Není důležitá
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" asp-page-handler="ToggleImportant" asp-route-noteId="@note.Id" 
                                            class="btn btn-sm btn-outline-warning" title="Označit jako důležitá">
                                        ⭐ Označit
                                    </button>
                                }

                                <button type="submit" asp-page-handler="Delete" asp-route-noteId="@note.Id" 
                                        class="btn btn-sm btn-outline-danger" 
                                        onclick="return confirm('Opravdu chcete smazat tuto poznámku?');">
                                    🗑️ Smazat
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
